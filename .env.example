# ZAONEXUS env vars - all OPTIONAL for v1.3 ecosystem live data.
# If unset, /ecosystem/[slug] pages render without live data blocks (no errors, just hidden).

# Farcaster live data (cast count, last cast preview)
# Default uses haatz.quilibrium.com - free, no API key, Cassie Heart's Neynar v2 mirror.
# See research/farcaster/589-haatz-coverage-cassie-casts-may2026/ in ZAOOS repo.
# Override only if you want to fall back to api.neynar.com (e.g., haatz down).
# FARCASTER_API_BASE=https://haatz.quilibrium.com  # default, no need to set
# FARCASTER_API_BASE=https://api.neynar.com         # only if explicitly switching to Neynar
# NEYNAR_API_KEY=your_key_here                       # required only if FARCASTER_API_BASE points at Neynar

# Token holder counts on brand pages (optional)
# Get key at https://dashboard.alchemy.com/apps
# ALCHEMY_API_KEY=your_key_here

# GitHub last commit on brand pages: no key needed for public repos (rate limit 60/h)
